{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG GETTEXT_VERSION=(?<currentValue>[\\d.]+)"
      ],
      "depNameTemplate": "autotools-mirror/gettext",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "automerge": true
    },
    {
      "matchManagers": ["custom.regex"],
      "automerge": true
    }
  ]
}
